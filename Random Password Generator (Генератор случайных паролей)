import sys
import json
import os
from datetime import datetime
from PyQt5.QtWidgets import (QApplication, QMainWindow, QWidget, QVBoxLayout, 
                             QHBoxLayout, QLabel, QLineEdit, QComboBox, 
                             QPushButton, QTableWidget, QTableWidgetItem,
                             QMessageBox, QDateEdit, QSpinBox, QGroupBox)
from PyQt5.QtCore import Qt, QDate

class FitnessTracker(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("Fitness Tracker")
        self.setGeometry(100, 100, 800, 600)
        
        # Initialize workout data
        self.workouts_file = "workouts.json"
        self.workouts = []
        self.load_workouts()
        
        # Workout types
        self.workout_types = [
            "Running", "Cycling", "Swimming", 
            "Weight Training", "Yoga", "HIIT",
            "Walking", "CrossFit", "Pilates"
        ]
        
        # Create central widget
        self.central_widget = QWidget()
        self.setCentralWidget(self.central_widget)
        
        # Main layout
        self.main_layout = QVBoxLayout()
        self.central_widget.setLayout(self.main_layout)
        
        # Add workout form
        self.setup_workout_form()
        
        # Filter controls
        self.setup_filter_controls()
        
        # Workouts table
        self.setup_workouts_table()
        
    def setup_workout_form(self):
        """Setup the form for adding new workouts"""
        form_group = QGroupBox("Add New Workout")
        form_layout = QVBoxLayout()
        
        # Date input
        date_layout = QHBoxLayout()
        date_layout.addWidget(QLabel("Date:"))
        self.date_input = QDateEdit()
        self.date_input.setDate(QDate.currentDate())
        self.date_input.setCalendarPopup(True)
        date_layout.addWidget(self.date_input)
        form_layout.addLayout(date_layout)
        
        # Workout type
        type_layout = QHBoxLayout()
        type_layout.addWidget(QLabel("Workout Type:"))
        self.type_input = QComboBox()
        self.type_input.addItems(self.workout_types)
        type_layout.addWidget(self.type_input)
        form_layout.addLayout(type_layout)
        
        # Duration
        duration_layout = QHBoxLayout()
        duration_layout.addWidget(QLabel("Duration (minutes):"))
        self.duration_input = QSpinBox()
        self.duration_input.setMinimum(1)
        self.duration_input.setMaximum(600)
        self.duration_input.setValue(30)
        duration_layout.addWidget(self.duration_input)
        form_layout.addLayout(duration_layout)
        
        # Add button
        self.add_button = QPushButton("Add Workout")
        self.add_button.clicked.connect(self.add_workout)
        form_layout.addWidget(self.add_button)
        
        form_group.setLayout(form_layout)
        self.main_layout.addWidget(form_group)
    
    def setup_filter_controls(self):
        """Setup filter controls for workouts"""
        filter_group = QGroupBox("Filter Workouts")
        filter_layout = QVBoxLayout()
        
        # Filter by date range
        date_filter_layout = QHBoxLayout()
        date_filter_layout.addWidget(QLabel("From:"))
        self.from_date_input = QDateEdit()
        self.from_date_input.setDate(QDate.currentDate().addMonths(-1))
        self.from_date_input.setCalendarPopup(True)
        date_filter_layout.addWidget(self.from_date_input)
        
        date_filter_layout.addWidget(QLabel("To:"))
        self.to_date_input = QDateEdit()
        self.to_date_input.setDate(QDate.currentDate())
        self.to_date_input.setCalendarPopup(True)
        date_filter_layout.addWidget(self.to_date_input)
        
        filter_layout.addLayout(date_filter_layout)
        
        # Filter by workout type
        type_filter_layout = QHBoxLayout()
        type_filter_layout.addWidget(QLabel("Workout Type:"))
        self.type_filter_input = QComboBox()
        self.type_filter_input.addItem("All Types")
        self.type_filter_input.addItems(self.workout_types)
        type_filter_layout.addWidget(self.type_filter_input)
        filter_layout.addLayout(type_filter_layout)
        
        # Filter button
        filter_button_layout = QHBoxLayout()
        self.filter_button = QPushButton("Apply Filters")
        self.filter_button.clicked.connect(self.apply_filters)
        filter_button_layout.addWidget(self.filter_button)
        
        self.clear_filter_button = QPushButton("Clear Filters")
        self.clear_filter_button.clicked.connect(self.clear_filters)
        filter_button_layout.addWidget(self.clear_filter_button)
        
        filter_layout.addLayout(filter_button_layout)
        filter_group.setLayout(filter_layout)
        self.main_layout.addWidget(filter_group)
    
    def setup_workouts_table(self):
        """Setup the table to display workouts"""
        self.workouts_table = QTableWidget()
        self.workouts_table.setColumnCount(4)
        self.workouts_table.setHorizontalHeaderLabels(["Date", "Workout Type", "Duration (min)", "Actions"])
        self.workouts_table.horizontalHeader().setStretchLastSection(True)
        self.workouts_table.setEditTriggers(QTableWidget.NoEditTriggers)
        
        self.main_layout.addWidget(QLabel("Workout History:"))
        self.main_layout.addWidget(self.workouts_table)
        self.update_workouts_table()
    
    def add_workout(self):
        """Add a new workout to the list"""
        # Get input values
        date = self.date_input.date().toString("yyyy-MM-dd")
        workout_type = self.type_input.currentText()
        duration = self.duration_input.value()
        
        # Basic validation
        if duration <= 0:
            QMessageBox.warning(self, "Invalid Input", "Duration must be positive!")
            return
        
        # Create workout entry
        workout = {
            "date": date,
            "type": workout_type,
            "duration": duration
        }
        
        # Add to workouts list
        self.workouts.append(workout)
        self.save_workouts()
        self.update_workouts_table()
        
        # Clear form
        self.date_input.setDate(QDate.currentDate())
        self.duration_input.setValue(30)
        
        QMessageBox.information(self, "Success", "Workout added successfully!")
    
    def apply_filters(self):
        """Apply filters to the workouts table"""
        self.update_workouts_table()
    
    def clear_filters(self):
        """Clear all filters"""
        self.from_date_input.setDate(QDate.currentDate().addMonths(-1))
        self.to_date_input.setDate(QDate.currentDate())
        self.type_filter_input.setCurrentIndex(0)
        self.update_workouts_table()
    
    def update_workouts_table(self):
        """Update the workouts table with filtered data"""
        # Get filter values
        from_date = self.from_date_input.date().toString("yyyy-MM-dd")
        to_date = self.to_date_input.date().toString("yyyy-MM-dd")
        workout_type = self.type_filter_input.currentText()
        
        # Filter workouts
        filtered_workouts = []
        for workout in self.workouts:
            # Date filter
            if workout["date"] < from_date or workout["date"] > to_date:
                continue
            
            # Type filter
            if workout_type != "All Types" and workout["type"] != workout_type:
                continue
            
            filtered_workouts.append(workout)
        
        # Update table
        self.workouts_table.setRowCount(len(filtered_workouts))
        
        for i, workout in enumerate(filtered_workouts):
            # Date
            date_item = QTableWidgetItem(workout["date"])
            
            # Workout type
            type_item = QTableWidgetItem(workout["type"])
            
            # Duration
            duration_item = QTableWidgetItem(str(workout["duration"]))
            
            # Delete button
            delete_button = QPushButton("Delete")
            delete_button.clicked.connect(lambda _, row=i: self.delete_workout(row))
            
            # Add items to table
            self.workouts_table.setItem(i, 0, date_item)
            self.workouts_table.setItem(i, 1, type_item)
            self.workouts_table.setItem(i, 2, duration_item)
            
            # Add button to cell
            self.workouts_table.setCellWidget(i, 3, delete_button)
    
    def delete_workout(self, row):
        """Delete a workout from the list"""
        # Get the workout date from the table
        workout_date = self.workouts_table.item(row, 0).text()
        
        # Find and remove the workout from the main list
        for i, workout in enumerate(self.workouts):
            if workout["date"] == workout_date:
                del self.workouts[i]
                break
        
        self.save_workouts()
        self.update_workouts_table()
    
    def save_workouts(self):
        """Save workouts to JSON file"""
        try:
            with open(self.workouts_file, 'w') as f:
                json.dump(self.workouts, f, indent=2)
        except Exception as e:
            QMessageBox.critical(self, "Error", f"Failed to save workouts: {str(e)}")
    
    def load_workouts(self):
        """Load workouts from JSON file"""
        if os.path.exists(self.workouts_file):
            try:
                with open(self.workouts_file, 'r') as f:
                    self.workouts = json.load(f)
            except Exception as e:
                QMessageBox.critical(self, "Error", f"Failed to load workouts: {str(e)}")
                self.workouts = []
        else:
            self.workouts = []


if __name__ == "__main__":
    app = QApplication(sys.argv)
    tracker = FitnessTracker()
    tracker.show()
    sys.exit(app.exec_())
