class CurrencyConverter(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("Currency Converter")
        self.setGeometry(100, 100, 600, 500)
        
        # Initialize data
        self.history_file = "conversion_history.json"
        self.history = []
        self.load_history()
        
        # API configuration
        self.api_url = "https://v6.exchangerate-api.com/v6/"
        self.api_key = "YOUR_API_KEY"  # Replace with actual API key
        
        # Supported currencies (can be extended)
        self.currencies = ["USD", "EUR", "GBP", "JPY", "CAD", "AUD", "CNY", "RUB"]
        
        # Create central widget
        self.central_widget = QWidget()
        self.setCentralWidget(self.central_widget)
        
        # Main layout
        self.main_layout = QVBoxLayout()
        self.central_widget.setLayout(self.main_layout)
        
        # Converter controls
        self.setup_converter_ui()
        
        # Conversion result display
        self.result_label = QLabel("Result will appear here")
        self.result_label.setAlignment(Qt.AlignCenter)
        self.result_label.setStyleSheet("font: bold 18px;")
        self.main_layout.addWidget(self.result_label)
        
        # History table
        self.setup_history_table()

    def setup_converter_ui(self):
        """Setup the converter interface"""
        converter_layout = QVBoxLayout()

        # Amount input
        amount_layout = QHBoxLayout()
        amount_layout.addWidget(QLabel("Amount:"))
        self.amount_input = QLineEdit()
        self.amount_input.setPlaceholderText("Enter amount")
        self.amount_input.setValidator(QDoubleValidator(0, 1e9, 2))
        amount_layout.addWidget(self.amount_input)
        converter_layout.addLayout(amount_layout)

        # Currency selection
        currency_layout = QHBoxLayout()

        # From currency
        currency_layout.addWidget(QLabel("From:"))
        self.from_currency = QComboBox()
        self.from_currency.addItems(self.currencies)
        currency_layout.addWidget(self.from_currency)

        # To currency
        currency_layout.addWidget(QLabel("To:"))
        self.to_currency = QComboBox()
        self.to_currency.addItems(self.currencies)
        self.to_currency.setCurrentIndex(1)  # Default to EUR
        currency_layout.addWidget(self.to_currency)

        converter_layout.addLayout(currency_layout)

        # Convert button
        self.convert_button = QPushButton("Convert")
        self.convert_button.clicked.connect(self.convert_currency)
        converter_layout.addWidget(self.convert_button)

        self.main_layout.addLayout(converter_layout)

    def setup_history_table(self):
        """Setup the history table"""
        self.history_table = QTableWidget()
        self.history_table.setColumnCount(5)
        self.history_table.setHorizontalHeaderLabels(
            ["Date", "Amount", "From", "To", "Result"]
        )
        self.history_table.horizontalHeader().setStretchLastSection(True)
        self.history_table.setEditTriggers(QTableWidget.NoEditTriggers)

        self.main_layout.addWidget(QLabel("Conversion History:"))
        self.main_layout.addWidget(self.history_table)
        self.update_history_table()

    def convert_currency(self):
        """Perform currency conversion with enhanced input validation"""
        # Validate amount input
        amount_text = self.amount_input.text().strip()
        if not amount_text:
            QMessageBox.warning(self, "Invalid Input",
                          "Please enter an amount to convert.")
            return

        try:
            amount = float(amount_text)
            if amount <= 0:
                QMessageBox.warning(self, "Invalid Input",
                      "Amount must be a positive number.")
                return
            if amount > 1e9:  # 1 billion — reasonable upper limit
                QMessageBox.warning(self, "Input Limit",
                      "Amount is too large. Please enter a value less than 1,000,000,000.")
                return
        except ValueError:
            QMessageBox.warning(self, "Invalid Input",
                  "Please enter a valid number.")
            return

        # Get currency selections
        from_curr = self.from_currency.currentText()
        to_curr = self.to_currency.currentText()

        # Check if currencies are selected
        if not from_curr or not to_curr:
            QMessageBox.warning(self, "Selection Error",
                  "Please select both source and target currencies.")
            return

        # Handle same currency case
        if from_curr == to_curr:
            result = amount
            self.result_label.setText(f"{amount} {from_curr} = {result} {to_curr}")
            self.add_to_history(amount, from_curr, to_curr, result)
            return

        # Proceed with API conversion
        self.perform_api_conversion(amount, from_curr, to_curr)

    def perform_api_conversion(self, amount, from_curr, to_curr):
        """Handle API request with error handling"""
        try:
            url = f"{self.api_url}{self.api_key}/pair/{from_curr}/{to_curr}"
            response = requests.get(url, timeout=10)

            if response.status_code != 200:
                raise Exception(f"API returned status {response.status_code}")

            data = response.json()
            if 'conversion_rate' not in data:
                raise KeyError("Conversion rate not found in API response")

            rate = data['conversion_rate']
            result = round(amount * rate, 2)
            self.result_label.setText(f"{amount} {from_curr} = {result} {to_curr}")
            self.add_to_history(amount, from_curr, to_curr, result)

        except requests.exceptions.Timeout:
            QMessageBox.critical(self, "Connection Error",
                  "Request timed out. Please check your internet connection.")
        except requests.exceptions.RequestException as e:
            QMessageBox.critical(self, "Connection Error",
                  f"Network error: {str(e)}")
        except KeyError as e:
            QMessageBox.critical(self, "Data Error",
                f"Missing data in API response: {str(e)}")
        except Exception as e:
            QMessageBox.critical(self, "Conversion Error",
                f"Failed to convert currency: {str(e)}")

    def add_to_history(self, amount, from_curr, to_curr, result):
        """Add a conversion to history"""
        from datetime import datetime
        entry = {
            "date": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
            "amount": amount,
            "from": from_curr,
            "to": to_curr,
            "result": result
        }
        self.history.append(entry)
        self.save_history()
        self.update_history_table()

