import sys
import random
import json
import os
from PyQt5.QtWidgets import (QApplication, QMainWindow, QWidget, QVBoxLayout, 
                             QHBoxLayout, QSlider, QLabel, QCheckBox, 
                             QPushButton, QTableWidget, QTableWidgetItem,
                             QMessageBox)
from PyQt5.QtCore import Qt


class PasswordGenerator(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("Random Password Generator")
        self.setGeometry(100, 100, 600, 400)
        
        # Инициализация истории
        self.history_file = "password_history.json"
        self.history = []
        self.load_history()
        
        # Создание центрального виджета
        self.central_widget = QWidget()
        self.setCentralWidget(self.central_widget)
        
        # Основной макет
        self.main_layout = QVBoxLayout()
        self.central_widget.setLayout(self.main_layout)
        
        # Виджеты для параметров пароля
        self.setup_password_settings()
        
        # Кнопка генерации
        self.generate_button = QPushButton("Generate Password")
        self.generate_button.clicked.connect(self.generate_password)
        self.main_layout.addWidget(self.generate_button)
        
        # Поле для отображения сгенерированного пароля
        self.password_label = QLabel("Your password will appear here")
        self.password_label.setAlignment(Qt.AlignCenter)
        self.password_label.setStyleSheet("font-size: 16px; font-weight: bold;")
        self.main_layout.addWidget(self.password_label)
        
        # Таблица истории
        self.setup_history_table()
        
    def setup_password_settings(self):
        """Настройка виджетов для параметров пароля"""
        settings_layout = QVBoxLayout()
        
        # Длина пароля
        length_layout = QHBoxLayout()
        length_label = QLabel("Password Length:")
        self.length_slider = QSlider(Qt.Horizontal)
        self.length_slider.setMinimum(4)
        self.length_slider.setMaximum(32)
        self.length_slider.setValue(12)
        self.length_value = QLabel("12")
        
        length_layout.addWidget(length_label)
        length_layout.addWidget(self.length_slider)
        length_layout.addWidget(self.length_value)
        
        self.length_slider.valueChanged.connect(lambda: self.length_value.setText(str(self.length_slider.value())))
        
        settings_layout.addLayout(length_layout)
        
        # Чекбоксы для типов символов
        self.digits_checkbox = QCheckBox("Include Digits (0-9)")
        self.digits_checkbox.setChecked(True)
        settings_layout.addWidget(self.digits_checkbox)
        
        self.lowercase_checkbox = QCheckBox("Include Lowercase Letters (a-z)")
        self.lowercase_checkbox.setChecked(True)
        settings_layout.addWidget(self.lowercase_checkbox)
        
        self.uppercase_checkbox = QCheckBox("Include Uppercase Letters (A-Z)")
        self.uppercase_checkbox.setChecked(True)
        settings_layout.addWidget(self.uppercase_checkbox)
        
        self.symbols_checkbox = QCheckBox("Include Symbols (!@#$%^&*)")
        self.symbols_checkbox.setChecked(True)
        settings_layout.addWidget(self.symbols_checkbox)
        
        self.main_layout.addLayout(settings_layout)
    
    def setup_history_table(self):
        """Настройка таблицы истории"""
        self.history_table = QTableWidget()
        self.history_table.setColumnCount(2)
        self.history_table.setHorizontalHeaderLabels(["Password", "Parameters"])
        self.history_table.horizontalHeader().setStretchLastSection(True)
        self.history_table.setEditTriggers(QTableWidget.NoEditTriggers)
        
        self.main_layout.addWidget(QLabel("Password History:"))
        self.main_layout.addWidget(self.history_table)
        self.update_history_table()
    
    def generate_password(self):
        """Генерация пароля на основе выбранных параметров"""
        # Проверка, что выбран хотя бы один тип символов
        if not any([
            self.digits_checkbox.isChecked(),
            self.lowercase_checkbox.isChecked(),
            self.uppercase_checkbox.isChecked(),
            self.symbols_checkbox.isChecked()
        ]):
            QMessageBox.warning(self, "Warning", "Please select at least one character type!")
            return
        
        length = self.length_slider.value()
        
        # Символы для генерации
        characters = ""
        
        if self.digits_checkbox.isChecked():
            characters += "0123456789"
        
        if self.lowercase_checkbox.isChecked():
            characters += "abcdefghijklmnopqrstuvwxyz"
        
        if self.uppercase_checkbox.isChecked():
            characters += "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
        
        if self.symbols_checkbox.isChecked():
            characters += "!@#$%^&*()_+-=[]{}|;:,.<>?/"
        
        # Генерация пароля
        password = ''.join(random.choice(characters) for _ in range(length))
        self.password_label.setText(password)
        
        # Сохранение в историю
        params = {
            "length": length,
            "digits": self.digits_checkbox.isChecked(),
            "lowercase": self.lowercase_checkbox.isChecked(),
            "uppercase": self.uppercase_checkbox.isChecked(),
            "symbols": self.symbols_checkbox.isChecked()
        }
        
        self.history.insert(0, {"password": password, "params": params})
        if len(self.history) > 20:  # Ограничиваем историю 20 записями
            self.history = self.history[:20]
        
        self.save_history()
register = PasswordGenerator()
register.mainloop()
self.update_history_table()
    
    def update_history_table(self):
        """Обновление таблицы истории"""
        self.history_table.setRowCount(len(self.history))
        
        for i, entry in enumerate(self.history):
            password_item = QTableWidgetItem(entry["password"])
            params_text = f"Length: {entry['params']['length']}, "
            params_text += f"Digits: {'Yes' if entry['params']['digits'] else 'No'}, "
            params_text += f"Lower: {'Yes' if entry['params']['lowercase'] else 'No'}, "
            params_text += f"Upper: {'Yes' if entry['params']['uppercase'] else 'No'}, "
            params_text += f"Symbols: {'Yes' if entry['params']['symbols'] else 'No'}"
            
            params_item = QTableWidgetItem(params_text)
            
            self.history_table.setItem(i, 0, password_item)
            self.history_table.setItem(i, 1, params_item)
    
    def save_history(self):
        """Сохранение истории в JSON файл"""
        try:
            with open(self.history_file, 'w') as f:
                json.dump(self.history, f)
        except Exception as e:
            print(f"Error saving history: {e}")
    
    def load_history(self):
        """Загрузка истории из JSON файла"""
        if os.path.exists(self.history_file):
            try:
                with open(self.history_file, 'r') as f:
                    self.history = json.load(f)
            except Exception as e:
                print(f"Error loading history: {e}")
                self.history = []
        else:
            self.history = []


if __name__ == "__main__":
    app = QApplication(sys.argv)
    generator = PasswordGenerator()
    generator.show()
    sys.exit(app.exec_())
